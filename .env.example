SECRET_KEY=change-me
HOST=127.0.0.1
PORT=5000
SESSION_IDLE_TIMEOUT_MINUTES=30

# Database: leave DATABASE_URL unset to use instance/reviewbridge.db (absolute path).
# Do NOT use sqlite:///instance/... — Flask resolves that to instance/instance/*.db.

# Jira configuration (real API mode — global fallback)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=RA
JIRA_ISSUE_TYPE=Task

# Zendesk configuration (real API mode — global fallback)
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=you@example.com
ZENDESK_API_TOKEN=your_zendesk_api_token
